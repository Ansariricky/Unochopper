	(text "MCU - STM32F405RGT"
		(exclude_from_sim no)
		(at 146.05 30.48 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "1158f620-feaf-4423-b5cc-6a862209152f")
	)
	(text "IMU INT signals the flight controller when new sensor\ndata is ready, eliminating continuous polling and reducing CPU load.\n"
		(exclude_from_sim no)
		(at 217.17 59.69 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "380f57ed-92e4-44ed-95ad-6d50f78b524f")
	)
	(text "SPI2 uses the APB1 bus and is dedicated to external flash storage, providing \nreliable high-speed access for configuration data and flight log recording."
		(exclude_from_sim no)
		(at 177.8 142.24 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "434e140f-21b0-4380-91d4-b2e6595e14b5")
	)
	(text "Crystal load capacitors are calculated using CL = (C1 × C2)/(C1 + C2) + Cstray, \nwhere CL is the crystal load capacitance, \nC1 and C2 are the load capacitors, and Cstray is the total stray capacitance from the \nPCB and MCU pins.\n"
		(exclude_from_sim no)
		(at 26.67 80.01 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "6ae9d55d-9c21-468d-9ede-0c24252a5033")
	)
	(text "USART1 uses the APB2 high speed bus and is \nreserved for RC and telemetry communication."
		(exclude_from_sim no)
		(at 189.23 115.57 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "6f5bc900-f5a1-41cd-8f64-32ccfdfebfe7")
	)
	(text "SWDIO and SWCLK provide the Serial Wire Debug interface used by \nST-Link for MCU programming, debugging, and firmware flashing.\n"
		(exclude_from_sim no)
		(at 189.23 90.17 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "71013edd-4741-4664-a98a-2860eacb2764")
	)
	(text "I2C1 is used for low-bandwidth environmental sensors such as the BMP390L \nbarometer, providing a simple shared bus interface while minimizing SPI \nresource usage."
		(exclude_from_sim no)
		(at 219.71 121.92 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "89d39036-8131-4309-b5ed-5f5d58865819")
	)
	(text "TIM1 is an advanced 16-bit timer with precise PWM generation, \nmaking it ideal for generating DShot signals for the motors."
		(exclude_from_sim no)
		(at 208.28 77.47 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "b346d719-0b62-4ac9-a81b-79bd5cb21353")
	)
	(text "SPI1 uses the high-speed APB2 bus and is dedicated \nfor the IMU to provide fast and low-latency.\n"
		(exclude_from_sim no)
		(at 194.31 69.85 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "c6c870dd-8115-4a30-80df-4d5ba6f78542")
	)
	(text "USART6 uses the APB2 high speed bus and is \nreserved for GPS or Raspberry Pi communication."
		(exclude_from_sim no)
		(at 100.33 95.25 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify right)
		)
		(uuid "e41e3c11-d3ba-422b-9692-af327dcd27ba")
	)
	(text "Datasheet - page 79 - 6.1.6 Power Supply Scheme - Figure 21"
		(exclude_from_sim no)
		(at 76.2 41.91 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "e809f13f-8150-4d5e-8d32-b2df62db187d")
	)
	(text "Datasheet - page 79 - 6.1.6 Power Supply Scheme - Figure 21"
		(exclude_from_sim no)
		(at 81.28 121.92 0)
		(effects
			(font
				(size 0.889 0.889)
			)
			(justify left)
		)
		(uuid "f38cf899-f3ed-41e6-9628-8f4a62a26885")
	)
